# Environment Variables

# MongoDB connection string
# - MongoDB Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net
# - Local MongoDB:  mongodb://localhost:27017
MONGODB_URI="mongodb+srv://singhsameer80618_db_user:bTI5L4gB73hT8u0k@iskcon-cluster.exn2tcp.mongodb.net/iskconTemple?retryWrites=true&w=majority&appName=iskcon-cluster"

DB_NAME="iskconTemple"

NODE_ENV="development"

# Admin authentication (required for the /admin panel)
# ADMIN_PASSWORD — the password you type on the /admin login screen
# SESSION_SECRET — a long random string used to sign the admin session cookie
#                  generate one with:  openssl rand -base64 32
ADMIN_PASSWORD=change-me-to-a-strong-password
SESSION_SECRET=change-me-openssl-rand-base64-32
